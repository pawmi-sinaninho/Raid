        },
        "raidMapOrientation": {
          "enum": [
            "HORIZONTAL",
            "VERTICAL",
            "HYBRID"
          ]
        },
        "primaryMetrics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "radarWarningIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
